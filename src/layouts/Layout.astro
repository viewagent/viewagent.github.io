---
// src/layouts/Layout.astro
// We might import a global CSS file later if needed
import '../styles/global.css';
import Header from '../components/Header.astro'; // Import the Header component we will create
import Footer from '../components/Footer.astro';

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="logo/viewsuite.png" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta name="description" content="ViewSuite: a 6-DoF view-planning benchmark on real 3D scenes. Frontier VLMs track local view changes but collapse at multi-turn planning; self-exploration with view graph distillation lifts a 7B VLM from 2.5% to 47.8%." />
        <meta name="keywords" content="ViewSuite, view planning, vision-language models, VLM, agent, camera pose, camera pose estimation, 6-DoF, active perception, spatial reasoning, spatial intelligence, 3D scene understanding, ScanNet, world model, reinforcement learning, self-exploration, view graph distillation, interactive view planning, prospective spatial reasoning, embodied AI" />
        <link rel="canonical" href="https://viewsuite.github.io/" />
        <meta name="author" content="Kangrui Wang, Linjie Li, Zhengyuan Yang, Shiqi Chen, Zihan Wang, Li Fei-Fei, Jiajun Wu, Leonidas Guibas, Lijuan Wang, Manling Li" />
        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://viewsuite.github.io/" />
        <meta property="og:title" content="Planning with the Views | ViewSuite" />
        <meta property="og:description" content="Can VLMs plan camera moves to find a target view? Frontier VLMs track views but fail to plan; self-exploration closes the gap." />
        <meta property="og:image" content="https://viewsuite.github.io/figures/environment_overview.png" />
        <!-- Twitter / X card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="Planning with the Views | ViewSuite" />
        <meta name="twitter:description" content="Can VLMs plan camera moves to find a target view? Frontier VLMs track views but fail to plan; self-exploration closes the gap." />
        <meta name="twitter:image" content="https://viewsuite.github.io/figures/environment_overview.png" />
        {/* We can link fonts or global styles here if necessary */}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">

    </head>
    <body>
        <Header /> {/* Add the Header component here */}
        <main>
            <slot /> {/* Page content from index.astro goes here */}
        </main>
        <Footer />
    </body>
</html>

<style is:global>
	:root {
		--header-height: 60px;
		--page-max-width: 1100px;
		--text-light: #555;
	}
	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}
	html {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		color: #252525;
		scroll-behavior: smooth;
	}
	body {
		min-height: 100vh;
		overflow-x: hidden;
	}
	main {
		padding-top: var(--header-height);
	}
</style>